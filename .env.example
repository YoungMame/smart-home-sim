# -------------------------------------------------------------------
# Smart Home Simulator — environment variables
#
# Copy this file to .env and adjust values for your setup.
# -------------------------------------------------------------------

# ── MQTT broker ─────────────────────────────────────────────────────
#
# Option A (default): use the bundled Mosquitto broker that ships with
#   this project.  Start it with:
#     docker compose --profile broker up -d
#   The services will automatically connect to it at the address below.
#
# Option B: point to an external broker that is already running in your
#   infrastructure (e.g. HiveMQ, EMQX, AWS IoT Core, or a broker
#   inside a larger docker-compose project).  Replace the value below
#   with your broker's URL and start without the "broker" profile:
#     docker compose up -d
#
# Default (bundled broker):
MQTT_BROKER_URL=mqtt://mqtt-broker:1883
# Example for external broker:
# MQTT_BROKER_URL=mqtt://my-broker.local:1883

# ── Simulator core ───────────────────────────────────────────────────
# HTTP port exposed by the Simulator API (logs · data · event triggers)
# CORE_PORT=4000

# ── API bridge ───────────────────────────────────────────────────────
# HTTP port for the per-device REST API
# HTTP_PORT=3000
